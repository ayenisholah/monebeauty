generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  email        String     @unique
  passwordHash String?
  role         Role       @default(CLIENT)
  name         String?
  locale       Locale?
  createdAt    DateTime   @default(now())
  client       Client?
  sessions     Session[]
  staff        StaffUser?
}

model Session {
  id         String   @id @default(cuid())
  tokenHash  String   @unique
  userId     String
  expiresAt  DateTime
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Service {
  id             String             @id @default(cuid())
  slug           String             @unique
  publicPath     String?
  category       ServiceCategory
  durationMin    Int                @default(60)
  bookable       Boolean            @default(true)
  priceFrom      Decimal?
  images         String[]           @default([])
  order          Int                @default(0)
  published      Boolean            @default(true)
  heroImageAlt   String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  archivedAt     DateTime?
  appointments   Appointment[]
  pricing        PricingItem[]
  contents       TreatmentContent[]
  procedureMedia ProcedureMedia[]
  practitioners  Practitioner[]     @relation("PractitionerToService")
  technologies   Technology[]       @relation("TechnologyBookingService")

  @@index([archivedAt, order])
}

model ProcedureMedia {
  id            String   @id @default(cuid())
  serviceId     String
  key           String
  image         String
  identities    Json
  sourceUrl     String
  sourceLicense String   @default("CLINIC_ARCHIVE")
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  service       Service  @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, key])
  @@index([serviceId])
}

model TreatmentContent {
  id                String            @id @default(cuid())
  serviceId         String
  locale            Locale
  h1                String
  shortDesc         String
  whatItIs          String
  suitableFor       String[]
  benefits          String[]
  processSteps      String[]
  safety            String
  preCare           String
  postCare          String
  contraindications String[]
  sessions          String
  results           String
  faq               Json
  seoTitle          String
  seoDescription    String
  ogImage           String?
  imageAlt          String?
  status            PublicationStatus @default(PUBLISHED)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  service           Service           @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([serviceId, locale])
  @@index([locale, status])
}

model Technology {
  id               String              @id @default(cuid())
  slug             String              @unique
  publicPath       String
  images           String[]
  order            Int                 @default(0)
  relatedServiceId String?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt
  archivedAt       DateTime?
  relatedService   Service?            @relation("TechnologyBookingService", fields: [relatedServiceId], references: [id], onDelete: SetNull)
  contents         TechnologyContent[]

  @@index([archivedAt, order])
}

model TechnologyContent {
  id             String            @id @default(cuid())
  technologyId   String
  locale         Locale
  name           String
  specification  String?
  summary        String
  body           String
  imageAlt       String?
  seoTitle       String?
  seoDescription String?
  status         PublicationStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  technology     Technology        @relation(fields: [technologyId], references: [id], onDelete: Cascade)

  @@unique([technologyId, locale])
  @@index([locale, status])
}

model ContentPage {
  id             String            @id @default(cuid())
  slug           String
  locale         Locale
  title          String
  hero           String?
  body           String
  seoTitle       String?
  seoDescription String?
  status         PublicationStatus @default(PUBLISHED)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@unique([slug, locale])
  @@index([slug])
  @@index([locale, status])
}

model Product {
  id         String           @id @default(cuid())
  slug       String           @unique
  category   ProductCategory
  size       String?
  price      Decimal
  currency   String           @default("EUR")
  order      Int              @default(0)
  published  Boolean          @default(true)
  images     String[]
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  archivedAt DateTime?
  cartItems  CartItem[]
  orderItems OrderItem[]
  contents   ProductContent[]

  @@index([archivedAt, order])
}

model ProductContent {
  id               String            @id @default(cuid())
  productId        String
  locale           Locale
  name             String
  description      String
  shortDescription String?
  imageAlt         String?
  seoTitle         String?
  seoDescription   String?
  status           PublicationStatus @default(PUBLISHED)
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  product          Product           @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([productId, locale])
  @@index([locale, status])
}

model Cart {
  id        String     @id @default(cuid())
  sessionId String?
  clientId  String?
  createdAt DateTime   @default(now())
  client    Client?    @relation(fields: [clientId], references: [id])
  items     CartItem[]
}

model CartItem {
  id        String  @id @default(cuid())
  cartId    String
  productId String
  qty       Int     @default(1)
  cart      Cart    @relation(fields: [cartId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Order {
  id                 String            @id @default(cuid())
  clientId           String?
  locale             Locale            @default(fi)
  status             OrderStatus       @default(PENDING)
  subtotal           Decimal
  total              Decimal
  currency           String            @default("EUR")
  email              String
  phone              String?
  notes              String?
  consentGdpr        Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @default(now()) @updatedAt
  confirmedAt        DateTime?
  fulfilledAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  client             Client?           @relation(fields: [clientId], references: [id])
  items              OrderItem[]
  messages           OutboundMessage[]
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  productId String
  name      String
  unitPrice Decimal
  qty       Int     @default(1)
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product @relation(fields: [productId], references: [id])
}

model Practitioner {
  id             String         @id @default(cuid())
  name           String
  role           String
  appointments   Appointment[]
  availabilities Availability[]
  staff          StaffUser?
  services       Service[]      @relation("PractitionerToService")
}

model StaffUser {
  id             String        @id @default(cuid())
  userId         String        @unique
  practitionerId String?       @unique
  workingHours   Json?
  daysOff        DateTime[]
  practitioner   Practitioner? @relation(fields: [practitionerId], references: [id])
  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Availability {
  id             String       @id @default(cuid())
  practitionerId String
  date           DateTime
  slots          Json
  practitioner   Practitioner @relation(fields: [practitionerId], references: [id], onDelete: Cascade)

  @@unique([practitionerId, date])
}

model Appointment {
  id                 String             @id @default(cuid())
  clientId           String
  practitionerId     String
  serviceId          String
  locale             Locale             @default(fi)
  start              DateTime
  end                DateTime
  status             AppointmentStatus  @default(BOOKED)
  channel            String?
  notes              String?
  procedureIndex     Int?
  procedureTitle     String?
  procedurePrice     String?
  history            Json?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @default(now()) @updatedAt
  confirmedAt        DateTime?
  completedAt        DateTime?
  cancelledAt        DateTime?
  cancellationReason String?
  client             Client             @relation(fields: [clientId], references: [id])
  practitioner       Practitioner       @relation(fields: [practitionerId], references: [id])
  service            Service            @relation(fields: [serviceId], references: [id])
  events             AppointmentEvent[]
  messages           OutboundMessage[]
}

model AppointmentEvent {
  id             String               @id @default(cuid())
  appointmentId  String
  kind           AppointmentEventKind
  actor          String
  previousStatus AppointmentStatus?
  nextStatus     AppointmentStatus?
  previousStart  DateTime?
  previousEnd    DateTime?
  nextStart      DateTime?
  nextEnd        DateTime?
  reason         String?
  at             DateTime             @default(now())
  appointment    Appointment          @relation(fields: [appointmentId], references: [id], onDelete: Cascade)

  @@index([appointmentId, at])
}

model OutboundMessage {
  id            String               @id @default(cuid())
  orderId       String?
  appointmentId String?
  kind          OutboundMessageKind
  channel       CommunicationChannel
  locale        Locale
  recipient     String
  subject       String?
  body          String
  html          String?
  actor         String
  dedupeKey     String?              @unique
  createdAt     DateTime             @default(now())
  order         Order?               @relation(fields: [orderId], references: [id], onDelete: Cascade)
  appointment   Appointment?         @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  attempts      DeliveryAttempt[]

  @@index([orderId, createdAt])
  @@index([appointmentId, createdAt])
}

model DeliveryAttempt {
  id                String          @id @default(cuid())
  messageId         String
  status            DeliveryStatus
  provider          String?
  providerMessageId String?
  errorDetail       String?
  attemptedAt       DateTime        @default(now())
  message           OutboundMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId, attemptedAt])
}

model Client {
  id                String        @id @default(cuid())
  userId            String?       @unique
  fullName          String
  phone             String
  email             String
  notes             String?
  contraindications String?
  consentGdpr       Boolean       @default(false)
  consentMarketing  Boolean       @default(false)
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt
  archivedAt        DateTime?
  appointments      Appointment[]
  carts             Cart[]
  chatSessions      ChatSession[]
  user              User?         @relation(fields: [userId], references: [id])
  orders            Order[]

  @@index([phone])
  @@index([email])
  @@index([archivedAt])
}

model Article {
  id          String           @id @default(cuid())
  slug        String           @unique
  published   Boolean          @default(false)
  publishedAt DateTime?
  coverAlt    String?
  coverImage  String?
  order       Int              @default(0)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  archivedAt  DateTime?
  contents    ArticleContent[]

  @@index([archivedAt, order])
}

model ArticleContent {
  id             String            @id @default(cuid())
  articleId      String
  locale         Locale
  title          String
  excerpt        String?
  body           String
  seoTitle       String?
  seoDescription String?
  status         PublicationStatus @default(DRAFT)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  article        Article           @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, locale])
  @@index([locale, status])
}

model PricingItem {
  id         String           @id @default(cuid())
  serviceId  String?
  category   ServiceCategory?
  label      String
  price      Decimal
  unit       String?
  order      Int              @default(0)
  archivedAt DateTime?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt
  service    Service?         @relation(fields: [serviceId], references: [id])
  contents   PricingContent[]

  @@index([archivedAt, order])
}

model PricingContent {
  id            String            @id @default(cuid())
  pricingItemId String
  locale        Locale
  label         String
  unit          String?
  status        PublicationStatus @default(DRAFT)
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  pricingItem   PricingItem       @relation(fields: [pricingItemId], references: [id], onDelete: Cascade)

  @@unique([pricingItemId, locale])
  @@index([locale, status])
}

model ChatSession {
  id               String            @id @default(cuid())
  locale           Locale
  messages         Json
  handoffRequested Boolean           @default(false)
  clientId         String?
  createdAt        DateTime          @default(now())
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  status           ChatHandoffStatus @default(OPEN)
  updatedAt        DateTime          @default(now()) @updatedAt
  archivedAt       DateTime?
  anonymizedAt     DateTime?
  client           Client?           @relation(fields: [clientId], references: [id])

  @@index([handoffRequested, status])
  @@index([updatedAt])
}

model Consent {
  id       String   @id @default(cuid())
  clientId String?
  type     String
  granted  Boolean
  at       DateTime @default(now())
}

model AuditLog {
  id       String   @id @default(cuid())
  actor    String
  action   String
  entity   String
  entityId String?
  at       DateTime @default(now())
}

enum Role {
  ADMIN
  STAFF
  CLIENT
}

enum Locale {
  en
  fi
  ru
}

enum ServiceCategory {
  FACE
  BODY
  HAIR
  INJECTABLE
  DEVICE
  LASER
  CONSULTATION
}

enum ProductCategory {
  AROSHA_BODY
  DIXIDOX_TRICHO
}

enum AppointmentStatus {
  BOOKED
  CONFIRMED
  COMPLETED
  CANCELLED
  RESCHEDULED
}

enum AppointmentEventKind {
  CONFIRMED
  RESCHEDULED
  COMPLETED
  CANCELLED
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PAID
  FULFILLED
  CANCELLED
}

enum CommunicationChannel {
  EMAIL
  SMS
}

enum OutboundMessageKind {
  ORDER_RECEIPT
  ORDER_CONFIRMATION
  ORDER_CANCELLATION
  APPOINTMENT_RECEIPT
  APPOINTMENT_CONFIRMATION
  APPOINTMENT_RESCHEDULED
  APPOINTMENT_CANCELLATION
  APPOINTMENT_REMINDER_24H
  APPOINTMENT_REMINDER_2H
  CUSTOM
}

enum DeliveryStatus {
  ACCEPTED
  FAILED
  SKIPPED
}

enum ChatHandoffStatus {
  OPEN
  RESOLVED
}

enum PublicationStatus {
  DRAFT
  PUBLISHED
}
