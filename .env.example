# Copy to .env and fill in. Never commit the real .env (it is git-ignored).

# --- Database (Postgres, EU-hosted for GDPR). Deferred until Phase 2/3. ---
DATABASE_URL="postgresql://user:password@localhost:5432/monebeauty?schema=public"

# --- AI chatbot (Phase 7) ---
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-5"
ANTHROPIC_TIMEOUT_MS="12000"

# --- Auth (Phase 5) ---
AUTH_SECRET=""
ADMIN_EMAIL=""
ADMIN_PASSWORD=""
ADMIN_NAME="Mone Beauty Admin"

# --- Notifications (Phase 6) ---
NOTIFICATIONS_ENABLED="true"
NOTIFICATION_FROM_EMAIL="Mone Beauty Clinic <info@monebeauty.fi>"
NOTIFICATION_DEFAULT_LOCALE="fi"
STAFF_NOTIFICATION_EMAILS=""       # comma-separated staff/admin emails
STAFF_NOTIFICATION_PHONES=""       # comma-separated E.164 phones for SMS alerts
EMAIL_API_KEY=""                   # Resend fallback key
RESEND_API_KEY=""                  # preferred for Resend
POSTMARK_SERVER_TOKEN=""           # alternative to Resend
SMS_API_KEY=""                     # webhook bearer token or Twilio auth fallback
SMS_WEBHOOK_URL=""                 # Finnish SMS gateway webhook alternative
SMS_FROM=""                        # SMS gateway sender where supported
SINCH_PROJECT_ID=""
SINCH_APP_ID=""
SINCH_ACCESS_KEY_ID=""             # OAuth client/key ID for the Sinch project
SINCH_ACCESS_KEY_SECRET=""         # OAuth client/key secret
SINCH_REGION="eu"
SINCH_SMS_SENDER=""                # Sinch number or approved alphanumeric sender
TWILIO_ACCOUNT_SID=""
TWILIO_AUTH_TOKEN=""
TWILIO_FROM=""
REMINDER_WINDOW_MINUTES="60"       # cron tolerance around 24h and 2h reminders

# --- Admin media uploads (Cloudinary; keep API secret server-only) ---
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""
CLOUDINARY_URL=""

# --- Stripe website payments (appointments remain paid at the clinic) ---
STRIPE_SECRET_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_FINLAND_SHIPPING_RATE_ID=""

# --- Analytics (Phase 8) ---
NEXT_PUBLIC_GA_ID=""    # Google Analytics 4 (G-XXXXXXX)

# --- Site ---
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
