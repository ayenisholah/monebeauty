{
  "name": "monebeauty",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev -p 5000",
    "build": "next build",
    "start": "next start -p 5000",
    "test": "tsx --test tests/*.test.ts",
    "lint": "eslint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "content:gen-calendar-services": "node scripts/gen-internal-calendar-services.mjs",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:seed": "tsx prisma/seed.ts",
    "db:create-admin": "tsx --env-file=.env scripts/create-admin.ts",
    "db:provision-calendar-staff": "tsx --env-file=.env scripts/provision-calendar-staff.ts",
    "db:sync-calendar-templates": "tsx --env-file=.env scripts/sync-calendar-templates.ts",
    "db:sync-content": "tsx scripts/sync-cms-from-generated.ts",
    "db:sync-content:force": "tsx scripts/sync-cms-from-generated.ts --force",
    "db:sync-procedure-media": "tsx scripts/sync-procedure-media.ts",
    "scheduling:migrate-v2": "tsx scripts/migrate-scheduling-v2.ts",
    "availability:cleanup-defaults": "tsx --env-file=.env scripts/cleanup-default-availability.ts",
    "db:sync-procedure-media:force": "tsx scripts/sync-procedure-media.ts --force",
    "db:rollback-procedure-media": "tsx scripts/rollback-procedure-media.ts",
    "notifications:reminders": "tsx scripts/send-reminders.ts",
    "notifications:test": "tsx scripts/test-notifications.ts",
    "api-logs:cleanup": "tsx scripts/cleanup-api-logs.ts",
    "chat:check-provider": "node --env-file=.env scripts/check-claude.mjs",
    "chat:smoke": "node scripts/smoke-chat.mjs"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.109.1",
    "@dnd-kit/core": "^6.3.1",
    "@phosphor-icons/react": "^2.1.10",
    "@prisma/client": "^6.19.3",
    "@swc/helpers": "^0.5.23",
    "cloudinary": "^2.10.0",
    "next": "16.2.9",
    "next-intl": "^4.13.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "stripe": "^22.1.1"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "prettier": "^3.9.4",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prisma": "^6.19.3",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
